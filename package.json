{
  "name": "svx-portal-app",
  "version": "1.0.19",
  "description": "SVX Reflector Portal - Desktop App for Mac, Windows and Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.gururf.svx-portal-app",
    "productName": "SVX Portal",
    "copyright": "Copyright © 2026 RF.Guru",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/tray-icon.png",
      "build/icon.png",
      "build/entitlements.mac.plist",
      "secrets.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "artifactName": "SVX-Portal-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "identity": "Dielectricum (C4KY27CT2C)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "appx",
          "arch": ["x64"]
        }
      ],
      "artifactName": "SVX-Portal-Setup-${arch}.${ext}",
      "icon": "build/icon.png"
    },
    "appx": {
      "applicationId": "SVXPortal",
      "displayName": "SVX Portal",
      "publisherDisplayName": "RF Guru",
      "identityName": "com.gururf.svx-portal-app",
      "backgroundColor": "#0b1220",
      "artifactName": "SVX-Portal-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "SVX-Portal-${arch}.${ext}",
      "category": "Utility",
      "icon": "build/icon.png"
    }
  },
  "author": "Guru-RF",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
